#!/usr/bin/env bash
# Git pre-commit hook — Unity .meta missing block (template, manual opt-in)
#
# Blocks commit if a staged Unity asset (.cs/.shader/.asset/.prefab/.mat/...) is missing
# its paired .meta file (or the .meta is unstaged).
#
# Why: prevents GUID corruption on other machines / CI.
# Recovery: focus Unity Editor → .meta auto-generated → git add → re-commit.
# Bypass (NOT recommended): git commit --no-verify
#
# Activation in your Unity project (one-time, after copying this file):
#   mkdir -p .claude/githooks
#   cp <plugin-root>/templates/githooks/unity-pre-commit .claude/githooks/pre-commit
#   chmod +x .claude/githooks/pre-commit
#   git config core.hooksPath .claude/githooks

set -e

# Unity asset extensions covered
EXTS_PATTERN='\.(cs|shader|asset|prefab|mat|controller|inputactions|anim|asmdef|unity|fbx|png|jpg|jpeg|tga|wav|mp3|ogg)$'

# Added/Modified only — Deleted handled separately (paired .meta should be deleted too)
staged_added_modified=$(git diff --cached --name-only --diff-filter=AM | grep -E "^Assets/" | grep -E "$EXTS_PATTERN" || true)

[ -z "$staged_added_modified" ] && exit 0

all_staged=$(git diff --cached --name-only)

missing=()

while IFS= read -r f; do
    [ -z "$f" ] && continue
    # .meta files themselves are not the subject of the check
    case "$f" in
        *.meta) continue ;;
    esac

    meta="${f}.meta"

    # case 1: working tree has no .meta — Unity hasn't generated it yet
    if [ ! -f "$meta" ]; then
        missing+=("$f → no .meta in working tree (focus Unity Editor)")
        continue
    fi

    # case 2: .meta exists in working tree but not staged
    if ! echo "$all_staged" | grep -qx "$meta"; then
        # OK if already committed and unchanged
        if ! git ls-files --error-unmatch "$meta" >/dev/null 2>&1; then
            missing+=("$f → $meta exists but not staged (git add required)")
        fi
    fi
done <<< "$staged_added_modified"

if [ ${#missing[@]} -gt 0 ]; then
    echo "" >&2
    echo "🚨 Commit blocked — missing .meta files:" >&2
    for m in "${missing[@]}"; do
        echo "   - $m" >&2
    done
    echo "" >&2
    echo "Prevents GUID corruption on other machines." >&2
    echo "→ Focus Unity Editor once → .meta auto-generates → git add → retry." >&2
    echo "→ Intentional bypass (NOT recommended): git commit --no-verify" >&2
    exit 1
fi

exit 0
